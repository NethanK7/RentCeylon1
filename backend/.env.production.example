# ── RentCeylon — Production environment template ──
# Copy to .env on your server and fill in real values, then:
#   php artisan key:generate
#   php artisan migrate --force
#   php artisan db:seed --class=CategorySeeder --force
#   npm ci && npm run build

APP_NAME=RentCeylon
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://rentceylon.lk

APP_LOCALE=en
APP_TIMEZONE=Asia/Colombo

# Domains allowed to authenticate against Sanctum (web + admin subdomain)
SANCTUM_STATEFUL_DOMAINS=rentceylon.lk,www.rentceylon.lk
FRONTEND_URL=https://rentceylon.lk

LOG_CHANNEL=stack
LOG_LEVEL=error

# ── Database: MySQL / MariaDB ──
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=rentceylon
DB_USERNAME=rentceylon
DB_PASSWORD=

# Use redis in production for sessions/cache/queue if available
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=true
QUEUE_CONNECTION=database
CACHE_STORE=database

# ── File storage: S3 / Cloudflare R2 (condition photos + ID docs, signed URLs) ──
FILESYSTEM_DISK=s3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=auto
AWS_BUCKET=rentceylon
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=true

# ── Mail (transactional: receipts, SLA alerts, review prompts) ──
MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="no-reply@rentceylon.lk"
MAIL_FROM_NAME="${APP_NAME}"

# ── Payments (Sri Lanka) ──
PAYHERE_MERCHANT_ID=
PAYHERE_MERCHANT_SECRET=
PAYHERE_APP_ID=
PAYHERE_APP_SECRET=
PAYHERE_SANDBOX=false
IPAY_MERCHANT_ID=
IPAY_API_KEY=
# Stripe fallback (international cards) — optional
STRIPE_KEY=
STRIPE_SECRET=

# ── SMS / OTP (Dialog Axiata or Mobitel) ──
SMS_PROVIDER=dialog
SMS_API_URL=
SMS_API_TOKEN=
SMS_SENDER_ID=RentCeylon
